generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String    @unique
  phone        String?
  passwordHash String
  farmerType   String?
  profiles     Profile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Profile {
  id           String   @id @default(cuid())
  userId       String
  profileName  String
  city         String?
  chakAreaName String?
  villageName  String?
  notes        String?
  zameen       Zameen[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Zameen {
  id             String   @id @default(cuid())
  profileId      String
  murabbaNumber  String?
  zameenName     String
  killaNumber    String?
  khasraNumber   String?
  totalAreaValue Float
  totalAreaUnit  String
  totalAreaSqft  Float
  ownershipType  String?
  notes          String?
  crops          Crop[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Crop {
  id               String   @id @default(cuid())
  zameenId         String
  cropName         String
  cropAreaValue    Float
  cropAreaUnit     String
  cropAreaSqft     Float
  startMonth       Int?
  startYear        Int?
  expectedEndMonth Int?
  expectedEndYear  Int?
  status           String   @default("Active")
  notes            String?
  expenses         Expense[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  zameen Zameen @relation(fields: [zameenId], references: [id], onDelete: Cascade)

  @@index([zameenId])
}

model Expense {
  id              String   @id @default(cuid())
  cropId          String
  expenseCategory String
  description     String
  amount          Float
  expenseDate     DateTime
  expenseMonth    Int
  expenseYear     Int
  paymentStatus   String?
  paymentMethod   String?
  notes           String?
  receiptImageUrl String?
  sharedGroupId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  crop Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([cropId])
  @@index([expenseMonth, expenseYear])
}