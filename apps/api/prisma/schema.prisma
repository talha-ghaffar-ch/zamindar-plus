generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  passwordHash String
  farmerType   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}