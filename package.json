{
  "name": "zamindar-plus",
  "version": "1.0.0",
  "description": "Farm ledger platform for managing zameen, crops, expenses, income, reports, and farm records.",
  "scripts": {
    "dev:frontend": "npm run dev -w apps/frontend",
    "build:frontend": "npm run build -w apps/frontend",
    "lint:frontend": "npm run lint -w apps/frontend",
    "dev:mobile": "npm run start -w apps/mobile",
    "android:mobile": "npm run android -w apps/mobile",
    "typecheck:mobile": "tsc --noEmit -p apps/mobile/tsconfig.json",
    "lint:mobile": "npm run lint -w apps/mobile",
    "test:mobile": "npm run test -w apps/mobile",
    "dev:backend": "npm run start:dev -w apps/backend",
    "build:backend": "npm run build -w apps/backend",
    "lint:backend": "npm run lint -w apps/backend",
    "prisma:generate": "npm run prisma:generate -w apps/backend",
    "prisma:migrate": "npm run prisma:migrate -w apps/backend",
    "build": "npm run build:frontend && npm run build:backend",
    "lint": "npm run lint:frontend && npm run lint:backend && npm run lint:mobile",
    "check": "npm run build && npm run typecheck:mobile && npm run lint && npm run test:mobile -- -- --runInBand"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talha-ghaffar-ch/zamindar-plus.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/talha-ghaffar-ch/zamindar-plus/issues"
  },
  "homepage": "https://github.com/talha-ghaffar-ch/zamindar-plus#readme",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
