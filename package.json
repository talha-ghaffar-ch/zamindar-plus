{
  "name": "zamindar-plus",
  "version": "1.0.0",
  "description": "Farm ledger platform for managing zameen, crops, expenses, income, reports, and farm records.",
  "scripts": {
    "test": "npm run test:api",
    "test:api": "docker compose up -d && npm run test -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build:web": "npm run build -w apps/web",
    "lint:web": "npm run lint -w apps/web",
    "dev:mobile": "npm run start -w apps/mobile",
    "android:mobile": "npm run android -w apps/mobile",
    "lint:mobile": "npm run lint -w apps/mobile",
    "test:mobile": "npm run test -w apps/mobile",
    "dev:api": "npm run start:dev -w apps/api",
    "build:api": "npm run build -w apps/api",
    "lint:api": "npm run lint -w apps/api",
    "prisma:generate": "npm run prisma:generate -w apps/api",
    "prisma:migrate": "npm run prisma:migrate -w apps/api",
    "seed:users": "npm run seed:users -w apps/api",
    "build": "npm run build:web && npm run build:api",
    "lint": "npm run lint:web && npm run lint:api && npm run lint:mobile",
    "check": "npm run build && npm run lint && npm run test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talha-ghaffar-ch/zamindar-plus.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "bugs": {
    "url": "https://github.com/talha-ghaffar-ch/zamindar-plus/issues"
  },
  "homepage": "https://github.com/talha-ghaffar-ch/zamindar-plus#readme",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
