{
  "name": "zamindar-plus",
  "version": "1.0.0",
  "description": "Farm ledger platform for managing zameen, crops, expenses, income, reports, and farm records.",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:web": "npm run dev -w apps/web",
