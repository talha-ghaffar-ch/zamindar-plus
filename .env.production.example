# Copy this file to .env.production on the EC2 server.
# Do not commit the real .env.production file.

# Public HTTPS host created from your Elastic IP.
# Example: APP_HOST=13.203.249.97.sslip.io
APP_HOST=your-elastic-ip.sslip.io
APP_URL=https://your-elastic-ip.sslip.io

# Browser calls the API through Caddy at the same HTTPS origin.
VITE_API_URL=/api
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Backend
PORT=3000
NODE_ENV=production
CORS_ORIGIN=https://your-elastic-ip.sslip.io
JWT_SECRET=replace-with-a-long-random-production-secret

# RDS PostgreSQL.
# If your RDS instance enforces SSL, append the SSL mode that works for your RDS setup.
DATABASE_URL=postgresql://zamindar_admin:replace-password@your-rds-endpoint.amazonaws.com:5432/zamindar_plus?schema=public

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Email
EMAIL_DELIVERY_ENABLED=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login
SMTP_PASSWORD=your-smtp-key
SMTP_FROM="Zamindar Plus <zamindarplus@gmail.com>"

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Optional one-time seed credentials
SEED_ADMIN_EMAIL=zamindarplus@gmail.com
SEED_ADMIN_PASSWORD=replace-with-a-secure-admin-password
SEED_TEST_EMAIL=test@example.com
SEED_TEST_PASSWORD=replace-with-a-secure-test-password
